# Copy these into your Vercel project Environment Variables.
# Formspree endpoint id (create a free form at https://formspree.io and paste the id, e.g. "xyzabcd")
NEXT_PUBLIC_FORMSPREE_ID=your_formspree_id

# Google Analytics Measurement ID (e.g. "G-XXXXXXXXXX"). Leave blank to disable.
NEXT_PUBLIC_GA_ID=

# Public site url used for SEO / sitemap
NEXT_PUBLIC_SITE_URL=https://modernclasses.vercel.app
